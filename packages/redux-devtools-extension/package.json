    "prepublish": "pnpm run type-check && pnpm run lint"
  },
  "devDependencies": {
    "redux": "^5.0.1",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.2"
  },
  "peerDependencies": {
    "redux": "^3.1.0 || ^4.0.0 || ^5.0.0"
  }
}
